SPRING_PROFILES_ACTIVE=prod
PORT=8080

DB_URL=jdbc:mysql://YOUR_RDS_ENDPOINT:3306/workly_db?createDatabaseIfNotExist=true&useSSL=true&serverTimezone=Asia/Kolkata
DB_USERNAME=YOUR_DB_USERNAME
DB_PASSWORD=YOUR_DB_PASSWORD

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
CORS_ALLOWED_ORIGIN_PATTERNS=https://vyaastechnologies.com,https://www.vyaastechnologies.com,https://app.vyaastechnologies.com
APP_FRONTEND_BASE_URL=https://vyaastechnologies.com

STORAGE_PROVIDER=s3 
AWS_REGION=ap-south-2
AWS_S3_BUCKET=YOUR_S3_BUCKET_NAME
AWS_S3_KEY_PREFIX=workly

MAIL_PROVIDER=smtp
MAIL_FROM_NAME=Flowvera
MAIL_FROM_ADDRESS=noreply@vyaastechnologies.com
MAIL_HTTP_TIMEOUT_SECONDS=20
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_STARTTLS_REQUIRED=false
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000

# Switch back to SES later after AWS approves production access:
# MAIL_PROVIDER=ses

APP_TIMEZONE=Asia/Kolkata
PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=10
PASSWORD_RESET_COOLDOWN_SECONDS=60
